# =============================================================================
# CodeScan Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# In development with no DATABASE_URL set, the app falls back to local SQLite.
# Only GROQ_API_KEY is required for the AI feature to work.
# =============================================================================

# ---- Flask ----
# A long random string for signing session cookies.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Set to 1 to enable debug mode (development only). 0 for production.
# NOTE: FLASK_ENV was removed in Flask 2.3 — use FLASK_DEBUG.
FLASK_DEBUG=1

# Select config: development | production | testing
FLASK_ENV_MODE=development

# ---- Database (Neon PostgreSQL in production) ----
# Leave EMPTY in development to use local SQLite (codescan_dev.db).
# In production, use Neon's POOLED connection string (the -pooler hostname):
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.aws.neon.tech/codescan?sslmode=require
DATABASE_URL=

# ---- Redis (rate limiting + cache) ----
# Leave as default for local dev. In production, set a password.
REDIS_URL=redis://localhost:6379/0

# ---- Groq AI (REQUIRED for AI explanations) ----
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=

# ---- Frontend origin (for CORS) ----
# Your React dev server URL. Change to your production domain on deploy.
FRONTEND_ORIGIN=http://localhost:5173

# ---- AWS (only needed for production deployment) ----
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
